# ── Database ────────────────────────────────────
DATABASE_URL=postgres://postgres:password@localhost:5432/identity_db?sslmode=disable

# ── Server ──────────────────────────────────────
GRPC_PORT=50051      # gRPC server (internal microservice traffic)
HTTP_PORT=8080       # HTTP server (health checks, metrics)
ENV=development      # development | production
